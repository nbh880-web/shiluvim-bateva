rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Units - anyone can read, only admin can write
    match /units/{unitId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Inquiries - anyone can create, only admin can read/update/delete
    match /inquiries/{inquiryId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Reviews - anyone can read visible ones, only admin can write
    match /reviews/{reviewId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Settings - anyone can read, only admin can write
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Tasks - only admin
    match /tasks/{taskId} {
      allow read, write: if request.auth != null;
    }

    // Calls - only admin
    match /calls/{callId} {
      allow read, write: if request.auth != null;
    }

    // Attractions - anyone can read, only admin can write
    match /attractions/{attractionId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Analytics - anyone can create, only admin can read
    match /analytics/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
    }
  }
}
